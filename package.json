{
  "name": "conduit",
  "version": "0.1.0",
  "description": "A managed execution environment for AI CLI agents",
  "author": {
    "name": "Doug Rathbone",
    "email": "dougrathbone@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/dougrathbone/conduit",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougrathbone/conduit.git"
  },
  "scripts": {
    "dev": "concurrently --names \"ui,server\" --prefix-colors \"cyan,magenta\" \"vite build --watch --config vite.server.config.ts\" \"tsx watch src/server/index.ts\"",
    "build": "vite build --config vite.server.config.ts && tsc -p tsconfig.server.json",
    "start": "node out/server/index.js",
    "docker:build": "docker build -t conduit .",
    "docker:run": "docker run -p 7456:7456 conduit",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives",
    "test": "vitest run",
    "seed": "tsx scripts/seed-global-mcps.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@octokit/rest": "^21.0.2",
    "@tanstack/react-query": "^5.62.16",
    "@uiw/react-codemirror": "^4.23.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
